# HelixaraAI environment
PORT=3007

# Local hermes-agent (Desktop install — no upstream fork)
HERMES_AGENT_ROOT=/Users/favl/Desktop/hermes-agent-main
HERMES_HOME=
HERMES_BRIDGE_URL=http://127.0.0.1:18790
HERMES_BRIDGE_PORT=18790
HERMES_FREE_MODEL=free

# Free local models (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional cloud (not free by default)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Privacy: vault | hybrid | connected
HELIXARA_PRIVACY_MODE=hybrid

# Elevated dual-control (owner AND superadmin must approve restricted paths)
# Use long random secrets in production.
HELIXARA_OWNER_TOKEN=
HELIXARA_SUPERADMIN_TOKEN=
# Lab only — enables demo tokens if secrets unset:
# HELIXARA_ALLOW_DEMO_ELEVATED=1
# Demo tokens: helixara-owner-demo-change-me / helixara-superadmin-demo-change-me

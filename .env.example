# HelixaraAI default port (scripts pin 3007)
PORT=3007

# Privacy: vault | hybrid | connected (vault = local Ollama only)
# HELIXARA_PRIVACY_MODE=hybrid

# Wi‑Fi monitoring (defensive / lab only)
# HELIXARA_WIFI_MODULE=on
# HELIXARA_WIFI_LAB_MODE=1
# HELIXARA_WIFI_LAB_ALLOWLIST=aa:bb:cc:11:22:01,aa:bb:cc:11:22:05
# WIDS_WEBHOOK_URL=

# --- LLM / agents ---
# Local Ollama (Llama 3.1)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# OpenAI ChatGPT (agent training / missions)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (Hermes-compatible multi-model routing)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openrouter/auto
# OPENROUTER_SITE_URL=https://github.com/FrankAsanteVanLaarhoven/HelixaraAI

# OpenClaw personal agent gateway (optional)
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_TOKEN=

# Telegram operator bot (authorized user only — not for SMS spoof campaigns)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_ID=

# Optional PennyLane/Qiskit bridge
# QUANTUM_BRIDGE_URL=http://127.0.0.1:8099

# Stealth egress
# HELIXARA_PROXIES=[{"id":"res1","url":"http://user:pass@proxy:8080","kind":"residential","region":"us"}]
# HELIXARA_TOR_SOCKS=socks5://127.0.0.1:9050
